<%-include('../cabecalho.ejs')%>
    <header>
        <h3>Editar Banda</h3>
    </header>
    <div class="content">
        <form id="form-musica" method="post" autocomplete="off">
            <div class="grid">
                <div>
                    <label for="nome">ID da Banda</label>
                    <input id="id" value="<%=banda.id%>" name="id" type="text" placeholder="Ex:Gope" required>
                </div>
                <div>
                    <label for="nome">Nome da Banda</label>
                    <input id="nome" value="<%=banda.nome%>" name="nome" type="text" placeholder="Ex:Gope" required>
                </div>
                <div>
                    <label for="duracao">País de Origem</label>
                    <input id="duracao" value="<%=banda.pais%>" name="duracao" type="text" placeholder="Ex:Gope"
                        required>
                </div>
                <div>
                    <label for="anoInicio">Ano de Início</label>
                    <input id="anoInicio" value="<%=banda.anoInicio%>" name="anoInicio" type="text"
                        placeholder="Ex:Gope" required>
                </div>
                <div class="field-help">Os campos com * são obrigatórios.</div>
                <footer>
                    <a type="button" class="btn ghost" id="btn-cancelar" href="/bandas/lst">Cancelar</a>
                    <button type="submit" class="btn primary">Editar Banda</button>
                </footer>
        </form>
    </div>

    <%-include('../rodape.ejs')%>