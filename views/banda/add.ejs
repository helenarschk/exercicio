<%- include('../cabecalho.ejs')%>
    <main class="container">
        <a href="/bandas" class="back-link">← Voltar para lista</a>

        <div class="form-container">
            <h2>Cadastrar Nova Banda</h2>

            <form method="post">
                <div class="form-group">
                    <label for="nome">Nome da Banda *</label>
                    <input type="text" id="nome" name="nome">
                </div>

                <div class="form-group">
                    <label for="pais">País de Origem *</label>
                    <input type="text" id="pais" name="pais">
                </div>

                <div class="form-group">
                    <label for="anoInicio">Ano de Início *</label>
                    <input type="text" id="anoInicio" name="anoInicio">
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="/bandas" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
    <%- include('../rodape.ejs')%>