<%- include('../cabecalho.ejs')%>
    <main class="container">
        <a href="/jogador" class="back-link">← Voltar para lista</a>

        <div class="form-container">
            <h2>Cadastrar Novo Jogador</h2>

            <form method="post">
                <div class="form-group">
                    <label for="nome">Nome do Jogador *</label>
                    <input type="text" id="nome" name="nome">
                </div>

                <div class="form-group">
                    <label for="numero">Número *</label>
                    <input type="number" id="numero" name="numero">
                </div>

                <div class="form-group">
                    <label for="selecao">Seleção *</label>
                    <input type="text" id="selecao" name="selecao">
                </div>

                <div class="form-group">
                    <label for="gols">Gols *</label>
                    <input type="number" id="gols" name="gols">
                </div>

                <div class="form-group">
                    <label for="assistencias">Assistências *</label>
                    <input type="number" id="assistencias" name="assistencias">
                </div>

                <div class="form-buttons">
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <a href="/jogador" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
    <%- include('../rodape.ejs')%>