<%-include('.. /cabecalho.ejs')%>
    <header>
        <h3>Editar Seleção</h3>
    </header>
    <div class="content">
        <form id="form-selecao" method="post" autocomplete="off">
            <div class="grid">
                <div>
                    <label for="nome">ID da Seleção</label>
                    <input id="id" value="<%=selecao.id%>" name="id" type="text" placeholder="Ex:Gope" required>
                </div>
                <div>
                    <label for="nome">Nome da Seleção</label>
                    <input id="nome" value="<%=selecao.nome%>" name="nome" type="text" placeholder="Ex:Gope" required>
                </div>
                <div>
                    <label for="cores">Cores</label>
                    <input id="cores" value="<%=selecao.cores%>" name="cores" type="text" placeholder="Ex:Gope"
                        required>
                </div>
                <div>
                    <label for="continentes">Continentes</label>
                    <input id="continentes" value="<%=selecao.continentes%>" name="continentes" type="text"
                        placeholder="Ex:Gope" required>
                </div>
                <div>
                    <label for="titulos">Títulos</label>
                    <input id="titulos" value="<%=selecao.titulos%>" name="titulos" type="number" placeholder="Ex:Gope"
                        required>
                </div>
            </div>
            <div class="field-help">Os campos com * são obrigatórios.</div>
            <footer>
                <a type="button" class="btn ghost" id="btn-cancelar" href="/selecao">Cancelar</a>
                <button type="submit" class="btn primary">Editar Seleção</button>
            </footer>
        </form>
    </div>

    <%-include('.. /rodape.ejs')%>