<%- include('../cabecalho.ejs')%>

    <main class="container">
        <div class="page-header">
            <h2>Lista de Artistas</h2>
            <a href="/artistas/add" class="btn btn-success">+ Novo Artista</a>
        </div>

        <div class="search">
            <form method="post">
                <input type="text" name="pesquisar" placeholder="Nome do artista" class="form-container">
                <input type="submit" value="Buscar" class="btn btn-success">
            </form>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>País</th>
                        <th>Ano de Nascimento</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <%artistas.forEach(artista=> {%>
                        <tr>
                            <td>
                                <%=artista.nome%>
                            </td>
                            <td>
                                <%=artista.pais%>
                            </td>
                            <td>
                                <%=artista.anoNascimento%>
                            </td>
                            <td>
                                <a href="/artistas/del/<%=artista.id%>" class="link">Excluir</a>
                                <a href="/artistas/edt/<%=artista.id%>" class="link">Editar</a>
                            </td>
                        </tr>
                        <%})%>
                </tbody>
            </table>
        </div>
    </main>

    <%- include('../rodape.ejs')%>