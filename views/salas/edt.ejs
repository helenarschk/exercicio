<%-include('../cabecalho.ejs')%>
    <header>
        <h3>Editar Sala</h3>
    </header>
    <div class="content">
        <form id="form-sala" method="post" autocomplete="off">
            <div class="grid">
                <div>
                    <label for="numero">Número da Sala</label>
                    <input id="numero" value="<%=sala.numero%>" name="numero" type="number" placeholder="Ex:101" required>
                </div>
                <div>
                    <label for="capacidade">Capacidade</label>
                    <input id="capacidade" value="<%=sala.capacidade%>" name="capacidade" type="number" placeholder="Ex:100" required>
                </div>
            </div>
            <div class="field-help">Os campos com * são obrigatórios.</div>
            <footer>
                <a type="button" class="btn ghost" id="btn-cancelar" href="/salas">Cancelar</a>
                <button type="submit" class="btn primary">Editar Sala</button>
            </footer>
        </form>
    </div>

    <%-include('../rodape.ejs')%>